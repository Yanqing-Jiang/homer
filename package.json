{
  "name": "homer",
  "version": "5.0.0",
  "description": "Hybrid Orchestration for Multi-model Execution and Routing",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx tsc && cp src/state/migrations/*.sql dist/state/migrations/ && echo \"{\\\"sha\\\": \\\"$(git rev-parse --short HEAD 2>/dev/null || echo 'unknown')\\\", \\\"time\\\": \\\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\\\"}\" > dist/.build-version",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "tui": "tsx src/tui/index.ts",
    "mcp": "tsx src/mcp/index.ts",
    "typecheck": "npx tsc --noEmit",
    "migrate": "tsx scripts/run-migrations.ts",
    "migrate:ideas": "tsx scripts/migrate-ideas.ts",
    "migrate:plans": "tsx scripts/migrate-plans.ts",
    "test:router": "tsx scripts/test-router.ts",
    "test:swarm": "npx tsx --test src/executors/__tests__/parse-swarm-json.test.ts",
    "app:build": "bash scripts/build-homer-app.sh /Users/yj/Applications/Homer.app",
    "app:service:status": "bash scripts/manage-app-service.sh status",
    "app:service:register": "bash scripts/manage-app-service.sh register",
    "app:service:unregister": "bash scripts/manage-app-service.sh unregister",
    "restart": "bash scripts/kickstart-daemon.sh",
    "restart:force": "bash scripts/kickstart-daemon.sh --force",
    "deploy": "npm run build && npm run app:build && node scripts/smoke-test.mjs && bash scripts/pre-restart-check.sh && npm run restart"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@azure/storage-blob": "^12.26.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^7.7.3",
    "@fastify/websocket": "^10.0.1",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@mozilla/readability": "^0.6.0",
    "@supabase/supabase-js": "^2.39.0",
    "@types/fs-ext": "^2.0.3",
    "better-sqlite3": "^11.3.0",
    "blessed": "^0.1.81",
    "chokidar": "^5.0.0",
    "chrono-node": "^2.9.0",
    "croner": "^10.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
    "fs-ext": "^2.1.1",
    "grammy": "^1.21.1",
    "jsonwebtoken": "^9.0.3",
    "linkedom": "^0.18.12",
    "openai": "^4.24.0",
    "pg": "^8.17.2",
    "pidlock": "^0.1.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "playwright": "^1.40.0",
    "yaml": "^2.8.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/blessed": "^0.1.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
