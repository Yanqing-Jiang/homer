# ====================================================================
# HOMER ENVIRONMENT — copy to .env and fill in.
#
# At minimum you need TELEGRAM_BOT_TOKEN + ALLOWED_CHAT_ID + one of
# the model providers (or a Claude Code CLI already authed). Everything
# else is opt-in.
# ====================================================================

# --- Owner identity (used in prompts, scraping, telephony) ------------
OWNER_DISPLAY_NAME=Your Name
OWNER_EMAIL=you@example.com
OWNER_PHONE=+15555550100
LINKEDIN_HANDLE=your-linkedin-handle
MEDIUM_PROFILE_URL=https://medium.com/@your-handle

# --- Telegram bot -----------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
ALLOWED_CHAT_ID=your_chat_id

# --- Session & logging -----------------------------------------------
SESSION_TTL_HOURS=4
LOG_LEVEL=info

# --- Model providers --------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
MOONSHOT_API_KEY=your_moonshot_api_key
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_KEY_Primary=your_gemini_primary_key

# --- ElevenLabs (voice + telephony) ----------------------------------
ELEVEN_LABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id
ELEVENLABS_PHONE_NUMBER_ID=your_elevenlabs_phone_number_id
HOMER_PHONE=+15555550101

# --- Supabase (optional auth + sync) ---------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
DATABASE_URL=postgresql://...

# --- Azure Blob Storage (optional media storage) ---------------------
AZURE_STORAGE_CONNECTION_STRING=your_azure_connection_string
AZURE_STORAGE_CONTAINER=homer-data

# --- Web server -------------------------------------------------------
WEB_EXPOSE_EXTERNALLY=true
HOMER_API_URL=https://your-tunnel.example.com   # public origin for telephony webhooks + azure-proxy

# --- Web UI build-time vars (set in web/.env.local) -------------------
# VITE_SUPER_USER_EMAIL=you@example.com
# VITE_API_BASE=http://127.0.0.1:3000
# VITE_SUPABASE_URL=http://127.0.0.1:3000/supabase
