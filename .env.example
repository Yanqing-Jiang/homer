# Homer environment
# Copy this file to .env. Empty credentials are valid for a minimal local boot;
# integrations enable themselves only when their required values are present.

# ---------------------------------------------------------------------
# Required for a minimal local daemon
# ---------------------------------------------------------------------

LOG_LEVEL=info
SESSION_TTL_HOURS=8

# The telephony server also provides GET /health. It can run locally without
# Twilio or ElevenLabs credentials; webhook signature checks are skipped when
# their secrets are empty.
TELEPHONY_ENABLED=true
TELEPHONY_HOST=127.0.0.1
TELEPHONY_PORT=3000

# ---------------------------------------------------------------------
# Optional state/path overrides
# ---------------------------------------------------------------------
# Defaults:
#   HOMER_HOME: current OS home
#   HOMER_ROOT: $HOMER_HOME/homer
#   HOMER_DATA_PATH: $HOMER_ROOT/data
#   DATABASE_PATH: $HOMER_DATA_PATH/homer.db
#   LOGS_PATH: $HOMER_ROOT/logs
#   MEMORY_PATH: $HOMER_HOME/memory
#   CLAUDE_DIR: $HOMER_HOME/.claude
#
# HOMER_HOME=
# HOMER_ROOT=
# HOMER_DATA_PATH=
# DATABASE_PATH=
# LOGS_PATH=
# HOMER_LOG_DIR=
# MEMORY_PATH=
# CLAUDE_DIR=
# BROWSER_PROFILES_PATH=
# LANES_PATH=
# UPLOAD_LANDING_PATH=
# ARCHIVE_PATH=
# WORK_ROOT=
# WORK_SCHEDULE_FILE=
# TRADING_SCHEDULE_ENABLED=0
# TRADING_SCHEDULE_FILE=
# TRADING_CWD=

# ---------------------------------------------------------------------
# Owner profile used in prompts and starter memory files
# ---------------------------------------------------------------------

OWNER_DISPLAY_NAME=Owner
OWNER_EMAIL=
OWNER_PHONE=
LINKEDIN_HANDLE=
MEDIUM_PROFILE_URL=
WEATHER_LOCATION=

# ---------------------------------------------------------------------
# Telegram bot (optional, enables chat/reminders/push notifications)
# ---------------------------------------------------------------------
# Get TELEGRAM_BOT_TOKEN from @BotFather and ALLOWED_CHAT_ID from @userinfobot.
# If either is empty, the daemon skips Telegram polling and keeps local services
# running.

TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_ID=

# ---------------------------------------------------------------------
# Model providers and local CLI paths (optional)
# ---------------------------------------------------------------------
# Homer can still boot without these. Runtime jobs that need a missing provider
# will fail or fall back according to their executor chain.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_API_KEY_Primary=
MOONSHOT_API_KEY=
NVIDIA_NIM_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# CLAUDE_PATH=
# CLAUDE_BIN=
# CODEX_PATH=
# KIMI_PATH=
# AGY_BIN=
# AGY_ROTATE_BIN=

# ---------------------------------------------------------------------
# Voice, calls, and SMS (optional)
# ---------------------------------------------------------------------

VOICE_ENABLED=false
ELEVEN_LABS_API_KEY=
# Optional override for the local sherpa-onnx speaker-ID model (voice ID is enabled
# iff this file exists). Defaults to ~/homer/models/voice/nemo_en_titanet_large.onnx
VOICE_ID_MODEL_PATH=
ELEVEN_LABS_VOICE_ID=
ELEVEN_LABS_MODEL=eleven_multilingual_v2
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=
HOMER_PHONE=

TELEPHONY_PUBLIC_URL=
# HOMER_API_URL is accepted as a backward-compatible alias for TELEPHONY_PUBLIC_URL.
# HOMER_API_URL=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_API_KEY_SID=

# ---------------------------------------------------------------------
# Optional storage and repository integrations
# ---------------------------------------------------------------------

AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=homer-data
GH_TOKEN=
GITHUB_TOKEN=

# ---------------------------------------------------------------------
# Runtime behavior knobs
# ---------------------------------------------------------------------

DRAIN_TIMEOUT_MS=15000
SHUTDOWN_TIMEOUT_MS=30000
PROCESS_TIMEOUT_ENFORCE=1
TUI_REFRESH_MS=1000
