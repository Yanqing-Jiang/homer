# Dependencies
node_modules/
dist/
build/

# Environment & secrets
.env
.env.local
.env.production
.env.*.local

# Credentials by filename (defence in depth — never commit these)
*.pem
*.key
*.p12
*.pfx
*.der
*.cer
*.crt
*credentials*.json
*serviceaccount*.json
*cookies*.json
google-accounts.json
.homer-claude-token

# Runtime data
data/
logs/
uploads/
night_mode/
output/

# config/ — specific sensitive subdirs only. The rest of config/ (notably
# config/com.homer.daemon.plist.template) DOES ship so the installer works
# on a fresh clone. Real secrets live in .env, never in tracked config files.
config/auth/
config/codesign/
config/.DS_Store

# Documentation & non-code files (user rule: no docs in nightly push)
*.md
*.csv
*.pptx
*.docx
# Exceptions — the public-facing docs DO ship
!README.md
!LICENSE
!LICENSE.md
!docs/INSTALL.md
!docs/CONTRIBUTING.md
!docs/telephony.md

# Internal agent / model instructions — never publish
CLAUDE.md
GEMINI.md
AGENTS.md

# Browser profiles
profiles/

# Backups & databases — NEVER push to GitHub (binary, large, sensitive)
backups/
*.backup.*
*.bak
*.backup
*.db
*.db-journal
*.db-wal
*.db-shm
*.db.zst
*.sqlite
*.sqlite3

# Binary blobs (use codesign-node.sh to regenerate locally)
bin/node

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# Local scratch / inspection scripts
tmp_*.py
inspect_*.py
_inspect_*.py
**/_inspect_*.py
**/temp_*.py
tmpclaude-*/
.traces/
scratch/

# Test artifacts (tests themselves are not tracked in this public repo)
coverage/
.nyc_output/
__tests__/
*.test.ts
*.test.tsx
*.test.js
*.spec.ts
vitest.config.ts

# Overnight workspaces (nested git repos)
workspaces/

# Temporary files
*.tmp
*.temp

# Backup of pre-rewrite git directory — local-only
.git.backup-pre-rewrite/
